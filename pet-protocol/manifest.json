{
  "manifest_version": 3,
  "name": "Pet Protocol",
  "version": "0.1.0",
  "description": "Your consciousness, as a pixel pet. Lives on every webpage.",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "http://localhost:19099/*"
  ],
  "web_accessible_resources": [{
    "resources": ["assets/*", "assets/cats/*"],
    "matches": ["<all_urls>"]
  }],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": { "32": "assets/icon32.png" }
  },
  "icons": { "32": "assets/icon32.png" },
  "background": { "service_worker": "src/background.js" }
}
